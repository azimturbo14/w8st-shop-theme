<div class="cart-drawer-overlay"></div>
<div class="cart-drawer">
  <div class="cart-drawer-header">
    <h2>{{ 'sections.cart.title' | t }}</h2>
    <button class="cart-close" aria-label="{{ 'sections.cart.close' | t }}">✕</button>
  </div>
  <div class="cart-items">
    <!-- Cart items will be loaded dynamically -->
  </div>
  <div class="cart-footer">
    <div class="cart-subtotal">
      <span>{{ 'sections.cart.subtotal' | t }}</span>
      <span data-cart-subtotal></span>
    </div>
    <p class="shipping-note">{{ 'sections.cart.shipping_note' | t }}</p>
    <a href="/checkout" class="cart-checkout-btn">{{ 'sections.cart.checkout' | t }}</a>
    <a href="/collections/all" class="cart-continue">{{ 'sections.cart.continue_shopping' | t }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
