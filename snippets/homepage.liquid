<section class="section hero-section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Streetwear essentials</p>
      <h1>Wear the streets. Own the game.</h1>
      <p>Clean urban fits, performance sportswear, and everyday essentials for your next move.</p>
      <div class="hero-actions">
        <a class="button button--gold" href="/collections/all">Shop the collection</a>
        <a class="button button--outline" href="/collections/new-arrivals">New arrivals</a>
      </div>
    </div>
    <div class="hero-card" aria-label="Wear the streets. Own the game.">
      <div class="hero-card__image">
        <div class="hero-placeholder">
          <span>W8ST</span>
          <strong>{{ settings.tagline }}</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="ticker-section" aria-label="Announcement ticker">
  <div class="ticker-track">
    <div class="ticker-content">
      <span>FREE TASHKENT DELIVERY • SAME DAY PICKUP • NEW DROPS EVERY FRIDAY • </span>
      <span>FREE TASHKENT DELIVERY • SAME DAY PICKUP • NEW DROPS EVERY FRIDAY • </span>
      <span>FREE TASHKENT DELIVERY • SAME DAY PICKUP • NEW DROPS EVERY FRIDAY • </span>
      <span>FREE TASHKENT DELIVERY • SAME DAY PICKUP • NEW DROPS EVERY FRIDAY • </span>
    </div>
  </div>
</section>

<section class="section category-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Shop by category</p>
      <h2>Build your W8st rotation</h2>
      <p>Choose your fit, your sport, and your everyday essentials.</p>
    </div>

    <div class="category-grid">
      <a class="category-card" href="/collections/clothing">
        <div class="category-card__media"><div class="category-placeholder">W8ST</div></div>
        <div class="category-card__info">
          <h3>Clothing</h3>
          <span>Shop clothing</span>
        </div>
      </a>
      <a class="category-card" href="/collections/sportswear">
        <div class="category-card__media"><div class="category-placeholder">W8ST</div></div>
        <div class="category-card__info">
          <h3>Sportswear</h3>
          <span>Shop sportswear</span>
        </div>
      </a>
      <a class="category-card" href="/collections/accessories">
        <div class="category-card__media"><div class="category-placeholder">W8ST</div></div>
        <div class="category-card__info">
          <h3>Accessories</h3>
          <span>Shop accessories</span>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="section product-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>Fresh drops</h2>
      <p>Add products to your Shopify catalog and this grid will show your real products automatically.</p>
    </div>

    <div class="product-grid" data-product-grid>
      {%- if collections.all.products_count > 0 -%}
        {%- for product in collections.all.products limit: 4 -%}
          {% render 'product-card', product: product, show_button: true %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {% render 'product-card', product: null %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<section class="section sport-section">
  <div class="container sport-layout">
    <div class="sport-copy">
      <p class="eyebrow">Performance</p>
      <h2>Sport collection</h2>
      <p>Use your Shopify collections to show training and active pieces here.</p>
      <a class="button button--gold" href="/collections/sportswear">Shop sportswear</a>
    </div>
    <div class="product-grid product-grid--sport">
      {%- if collections.sportswear.products_count > 0 -%}
        {%- for product in collections.sportswear.products limit: 4 -%}
          {% render 'product-card', product: product, show_button: true %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {% render 'product-card', product: null %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<section class="promo-banner section">
  <div class="container promo-banner__inner">
    <div>
      <p class="eyebrow">Limited offer</p>
      <h2>Weekend drop sale</h2>
      <p>Edit this message in the theme files or theme editor when you are ready to run a promotion.</p>
    </div>
    <a class="button button--gold" href="/collections/sale">Shop sale</a>
  </div>
</section>

<section class="section lookbook-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">As worn in Tashkent</p>
      <h2>Street lookbook</h2>
      <p>Add lookbook images from Shopify when you are ready.</p>
    </div>

    <div class="lookbook-grid">
      <a class="lookbook-card" href="/collections/all"><div class="lookbook-placeholder">Look 1</div><span>Look 1</span></a>
      <a class="lookbook-card" href="/collections/all"><div class="lookbook-placeholder">Look 2</div><span>Look 2</span></a>
      <a class="lookbook-card" href="/collections/all"><div class="lookbook-placeholder">Look 3</div><span>Look 3</span></a>
      <a class="lookbook-card" href="/collections/all"><div class="lookbook-placeholder">Look 4</div><span>Look 4</span></a>
    </div>
  </div>
</section>

<section class="section trust-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Why W8st</p>
      <h2>Built for clean fits and easy shopping</h2>
    </div>
    <div class="trust-grid">
      <div class="trust-card"><div class="trust-card__icon">🚚</div><h3>Free shipping</h3><p>Free delivery across Tashkent over your chosen threshold.</p></div>
      <div class="trust-card"><div class="trust-card__icon">↩️</div><h3>Easy returns</h3><p>Simple returns if the fit is not right.</p></div>
      <div class="trust-card"><div class="trust-card__icon">✓</div><h3>Quality guaranteed</h3><p>Checked before dispatch for clean finishing.</p></div>
    </div>
  </div>
</section>
