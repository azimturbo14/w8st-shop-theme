<section class="section hero-section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">W8st Shop</p>
      <h1>Wear the streets. Own the game.</h1>
      <p>Streetwear, sportswear, shoes, backpacks, and everyday essentials.</p>
      <div class="hero-actions">
        <a class="button button--gold" href="#products">Shop products</a>
        <a class="button button--outline" href="/pages/contact">Contact us</a>
      </div>
    </div>
    <div class="hero-card" aria-label="Wear the streets. Own the game.">
      <div class="hero-card__image">
        <div class="hero-placeholder">
          <span>W8ST</span>
          <strong>{{ settings.tagline }}</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section product-catalog" id="products">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Shop all</p>
      <h2>Available products</h2>
      <p>All active Online Store products appear here. Filter them by category.</p>
    </div>

    <div class="product-filters" aria-label="Product filters">
      <button class="product-filter is-active" type="button" data-product-filter="all" aria-pressed="true">All</button>
      <button class="product-filter" type="button" data-product-filter="shoes" aria-pressed="false">Shoes</button>
      <button class="product-filter" type="button" data-product-filter="backpacks" aria-pressed="false">Backpacks</button>
      <button class="product-filter" type="button" data-product-filter="clothes" aria-pressed="false">Clothes</button>
      <button class="product-filter" type="button" data-product-filter="sportwear" aria-pressed="false">Sportwear</button>
      <button class="product-filter" type="button" data-product-filter="streetwear" aria-pressed="false">Streetwear</button>
    </div>

    <div class="product-grid product-catalog__grid" data-product-grid>
      {%- if collections.all.products_count > 0 -%}
        {%- for product in collections.all.products limit: 48 -%}
          {% render 'product-card', product: product, show_button: true %}
        {%- endfor -%}
      {%- else -%}
        <div class="empty-state product-catalog__empty">
          <h2>No products yet</h2>
          <p>Add products in Shopify and publish them to the Online Store channel.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
