[
  {
    "name": "theme_info",
    "theme_name": "W8st Shop",
    "theme_version": "3.0.0",
    "theme_author": "W8st Team",
    "theme_documentation_url": "https://help.shopify.com",
    "theme_support_url": "https://support.shopify.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background color",
        "default": "#1a1208"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface color",
        "default": "#2a1e0e"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color",
        "default": "#f5e6c8"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text color",
        "default": "#b8a882"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color (gold)",
        "default": "#e8b84b"
      },
      {
        "type": "color",
        "id": "color_accent_text",
        "label": "Accent text color",
        "default": "#1a1208"
      }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "text",
        "id": "tagline",
        "label": "Tagline",
        "default": "Wear the streets. Own the game."
      },
      {
        "type": "text",
        "id": "location",
        "label": "Store location",
        "default": "Tashkent, Uzbekistan"
      }
    ]
  },
  {
    "name": "Announcement",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_announcement",
        "label": "Show announcement bar",
        "default": true
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "Free delivery across Tashkent over 500 000 UZS"
      }
    ]
  },
  {
    "name": "Product",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_size_guide",
        "label": "Show size guide",
        "default": true
      },
      {
        "type": "text",
        "id": "size_guide_title",
        "label": "Size guide title",
        "default": "Size guide"
      },
      {
        "type": "richtext",
        "id": "size_guide_body",
        "label": "Size guide content",
        "default": "<p>Measure your chest, waist and hips. Choose your usual streetwear fit or size up for an oversized look.</p>"
      },
      {
        "type": "checkbox",
        "id": "show_shipping_accordion",
        "label": "Show shipping accordion on product page",
        "default": true
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_free_shipping",
        "label": "Show free shipping progress",
        "default": true
      },
      {
        "type": "text",
        "id": "free_shipping_label",
        "label": "Free shipping label",
        "default": "Free shipping in Tashkent over 500 000 UZS"
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (UZS)",
        "default": 500000
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "text",
        "id": "footer_column_1_title",
        "label": "Footer column 1 title",
        "default": "Shop"
      },
      {
        "type": "textarea",
        "id": "footer_column_1_links",
        "label": "Footer column 1 links (one per line)",
        "default": "New Arrivals\nClothing\nSportswear\nAccessories"
      },
      {
        "type": "text",
        "id": "footer_column_2_title",
        "label": "Footer column 2 title",
        "default": "Help"
      },
      {
        "type": "textarea",
        "id": "footer_column_2_links",
        "label": "Footer column 2 links (one per line)",
        "default": "About\nContact\nShipping & Returns"
      },
      {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram URL",
        "default": "https://instagram.com/w8stshop"
      },
      {
        "type": "url",
        "id": "telegram_url",
        "label": "Telegram URL",
        "default": "https://t.me/w8stshop"
      }
    ]
  }
]
