<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ 'customer.account.title' | t }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  {% render 'header' %}
  <main class="customer-template">
    <h1>{{ 'customer.account.title' | t }}</h1>
    <p>{{ customer.name }}</p>
    <a href="/account/logout">{{ 'customer.account.logout' | t }}</a>
    <h2>{{ 'customer.account.orders' | t }}</h2>
    {% if customer.orders.size > 0 %}
      <table class="orders-table">
        <thead>
          <tr>
            <th>{{ 'customer.account.order' | t }}</th>
            <th>{{ 'customer.account.date' | t }}</th>
            <th>{{ 'customer.account.total' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {% for order in customer.orders %}
          <tr>
            <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
            <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
            <td>{{ order.total_price | money }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>{{ 'customer.account.no_orders' | t }}</p>
    {% endif %}
  </main>
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
