{%- comment -%}
  Customer order template
{%- endcomment -%}

<div class="customer-order-page">
  <div class="container">
    <div class="order-header">
      <a href="{{ routes.account_url }}" class="button button--outline">&larr; {{ 'customer.account.return' | default: "Back to account" }}</a>
      <h1>{{ 'customer.order.title' | t }} {{ order.name }}</h1>
    </div>

    <div class="order-content">
      <div class="order-status">
        <h2>{{ 'customer.order.status_title' | default: "Order Status" }}</h2>
        <p class="status-badge">{{ order.financial_status_label }}</p>
        <p class="order-date">{{ 'customer.order.date' | t }}: {{ order.created_at | date: "%B %d, %Y" }}</p>
      </div>

      <div class="order-details-grid">
        <div class="order-shipping">
          <h3>{{ 'customer.order.shipping_address' | t }}</h3>
          <address>
            {{ order.shipping_address.first_name }} {{ order.shipping_address.last_name }}<br>
            {{ order.shipping_address.street }}<br>
            {{ order.shipping_address.city }}, {{ order.shipping_address.province }} {{ order.shipping_address.zip }}<br>
            {{ order.shipping_address.country }}<br>
            {{ order.shipping_address.phone }}
          </address>
        </div>

        <div class="order-billing">
          <h3>{{ 'customer.order.billing_address' | t }}</h3>
          <address>
            {{ order.billing_address.first_name }} {{ order.billing_address.last_name }}<br>
            {{ order.billing_address.street }}<br>
            {{ order.billing_address.city }}, {{ order.billing_address.province }} {{ order.billing_address.zip }}<br>
            {{ order.billing_address.country }}<br>
            {{ order.billing_address.phone }}
          </address>
        </div>
      </div>

      <div class="order-items">
        <h3>{{ 'customer.order.items' | t }}</h3>
        <table class="order-table">
          <thead>
            <tr>
              <th>{{ 'customer.order.product' | t }}</th>
              <th>{{ 'customer.order.sku' | t }}</th>
              <th>{{ 'customer.order.price' | t }}</th>
              <th>{{ 'customer.order.quantity' | t }}</th>
              <th>{{ 'customer.order.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for line_item in order.line_items -%}
              <tr>
                <td>
                  <div class="line-item-info">
                    {% if line_item.image %}
                      <img src="{{ line_item.image | image_url: width: 100 }}" alt="{{ line_item.title }}">
                    {% endif %}
                    <div>
                      <strong>{{ line_item.title }}</strong>
                      {% if line_item.variant.title != 'Default Title' %}
                        <p class="variant-title">{{ line_item.variant.title }}</p>
                      {% endif %}
                    </div>
                  </div>
                </td>
                <td>{{ line_item.sku }}</td>
                <td>{{ line_item.original_price | money }}</td>
                <td>{{ line_item.quantity }}</td>
                <td>{{ line_item.final_line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
          <tfoot>
            <tr>
              <td colspan="4">{{ 'customer.order.subtotal' | t }}</td>
              <td>{{ order.line_items_subtotal_price | money }}</td>
            </tr>
            {%- if order.shipping_price > 0 -%}
              <tr>
                <td colspan="4">{{ 'customer.order.shipping' | t }}</td>
                <td>{{ order.shipping_price | money }}</td>
              </tr>
            {%- endif -%}
            {%- for discount in order.discounts -%}
              <tr class="discount">
                <td colspan="4">{{ discount.title }}</td>
                <td>-{{ discount.amount | money }}</td>
              </tr>
            {%- endfor -%}
            <tr class="total">
              <td colspan="4">{{ 'customer.order.total' | t }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          </tfoot>
        </table>
      </div>

      {%- if order.note != blank -%}
        <div class="order-note">
          <h3>{{ 'customer.order.note' | t }}</h3>
          <p>{{ order.note }}</p>
        </div>
      {%- endif -%}

      {%- if order.fulfillments.size > 0 -%}
        <div class="order-fulfillments">
          <h3>{{ 'customer.order.fulfillment' | t }}</h3>
          {%- for fulfillment in order.fulfillments -%}
            <div class="fulfillment">
              <p><strong>{{ 'customer.order.fulfilled_at' | t }}:</strong> {{ fulfillment.created_at | date: "%B %d, %Y" }}</p>
              {%- if fulfillment.tracking_number -%}
                <p><strong>{{ 'customer.order.tracking' | t }}:</strong> 
                  {%- if fulfillment.tracking_url -%}
                    <a href="{{ fulfillment.tracking_url }}" target="_blank">{{ fulfillment.tracking_number }}</a>
                  {%- else -%}
                    {{ fulfillment.tracking_number }}
                  {%- endif -%}
                </p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.customer-order-page {
  padding: 60px 0;
}

.order-header {
  margin-bottom: 40px;
}

.order-header a {
  margin-bottom: 20px;
  display: inline-block;
}

.order-header h1 {
  font-size: 2.5rem;
  color: var(--color-text);
}

.order-content {
  max-width: 1000px;
}

.order-status {
  background: var(--color-surface);
  padding: 30px;
  border-radius: var(--radius-lg);
  margin-bottom: 30px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.order-status h2 {
  margin-bottom: 15px;
  color: var(--color-text);
}

.status-badge {
  display: inline-block;
  padding: 8px 16px;
  background: var(--color-accent);
  color: var(--color-accent-text);
  border-radius: var(--radius-md);
  font-weight: 600;
  margin-bottom: 10px;
}

.order-date {
  color: var(--color-muted);
}

.order-details-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 30px;
}

.order-shipping,
.order-billing {
  background: var(--color-surface);
  padding: 25px;
  border-radius: var(--radius-lg);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.order-shipping h3,
.order-billing h3 {
  margin-bottom: 15px;
  color: var(--color-text);
}

address {
  font-style: normal;
  color: var(--color-muted);
  line-height: 1.6;
}

.order-items {
  background: var(--color-surface);
  padding: 30px;
  border-radius: var(--radius-lg);
  margin-bottom: 30px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.order-items h3 {
  margin-bottom: 20px;
  color: var(--color-text);
}

.order-table {
  width: 100%;
  border-collapse: collapse;
}

.order-table th,
.order-table td {
  padding: 15px;
  text-align: left;
  border-bottom: 1px solid rgba(245, 230, 200, 0.1);
}

.order-table th {
  color: var(--color-muted);
  font-weight: 500;
  font-size: 0.9rem;
}

.line-item-info {
  display: flex;
  gap: 15px;
  align-items: center;
}

.line-item-info img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: var(--radius-sm);
}

.variant-title {
  font-size: 0.85rem;
  color: var(--color-muted);
  margin-top: 5px;
}

.order-table tfoot td {
  font-weight: 600;
  color: var(--color-text);
}

.order-table tfoot .total td {
  font-size: 1.2rem;
  color: var(--color-accent);
  border-top: 2px solid var(--color-accent);
}

.order-note,
.order-fulfillments {
  background: var(--color-surface);
  padding: 30px;
  border-radius: var(--radius-lg);
  margin-bottom: 20px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.order-note h3,
.order-fulfillments h3 {
  margin-bottom: 15px;
  color: var(--color-text);
}

.order-note p,
.fulfillment p {
  color: var(--color-muted);
  margin-bottom: 10px;
}

@media (max-width: 768px) {
  .order-details-grid {
    grid-template-columns: 1fr;
  }

  .order-table {
    font-size: 0.85rem;
  }

  .order-table th,
  .order-table td {
    padding: 10px 5px;
  }

  .line-item-info {
    flex-direction: column;
    align-items: flex-start;
  }
}
{% endstylesheet %}
