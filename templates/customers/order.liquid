<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ 'customer.order.title' | t }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  {% render 'header' %}
  <main class="customer-template">
    <h1>{{ 'customer.order.title' | t }} {{ order.name }}</h1>
    <a href="/account">{{ 'customer.order.back' | t }}</a>
    {{ content_for_layout }}
  </main>
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
