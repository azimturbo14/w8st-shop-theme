<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ 'customer.register.title' | t }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  {% render 'header' %}
  <main class="customer-template">
    <div class="customer-form-wrapper">
      <h1>{{ 'customer.register.title' | t }}</h1>
      {% form 'create_customer' %}
        <div class="form-group">
          <label class="form-label" for="first-name">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" id="first-name" name="customer[first_name]" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label" for="last-name">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" id="last-name" name="customer[last_name]" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label" for="email">{{ 'customer.register.email' | t }}</label>
          <input type="email" id="email" name="customer[email]" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">{{ 'customer.register.password' | t }}</label>
          <input type="password" id="password" name="customer[password]" class="form-input" required>
        </div>
        <button type="submit" class="btn-gold">{{ 'customer.register.submit' | t }}</button>
      {% endform %}
      <p><a href="/account/login">{{ 'customer.register.login' | t }}</a></p>
    </div>
  </main>
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
