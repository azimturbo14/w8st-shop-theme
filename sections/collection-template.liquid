<section class="section collection-page">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ collection.title }}</h1>
      <p>{{ collection.description }}</p>
    </div>

    <div class="collection-toolbar">
      <form class="collection-sort" method="get">
        <label for="SortBy">{{ 'sections.collection.sort' | t }}</label>
        <select id="SortBy" name="sort_by" onchange="this.form.submit()">
          <option value="manual">{{ 'sections.collection.manual' | t }}</option>
          <option value="best-selling">{{ 'sections.collection.best_selling' | t }}</option>
          <option value="created-descending">{{ 'sections.collection.newest' | t }}</option>
          <option value="price-ascending">{{ 'sections.collection.price_asc' | t }}</option>
          <option value="price-descending">{{ 'sections.collection.price_desc' | t }}</option>
        </select>
      </form>
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products_count > 0 -%}
        <div class="product-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product, show_button: true %}
          {%- endfor -%}
        </div>

        <div class="pagination" role="navigation" aria-label="{{ 'sections.collection.pagination' | t }}">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr; {{ 'sections.collection.previous' | t }}</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span class="is-active">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{{ 'sections.collection.next' | t }} &rarr;</a>{%- endif -%}
        </div>
      {%- else -%}
        <div class="empty-state">
          <h2>{{ 'sections.collection.empty_title' | t }}</h2>
          <p>{{ 'sections.collection.empty_text' | t }}</p>
          <a class="button button--gold" href="/collections/all">{{ 'sections.collection.browse_all' | t }}</a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop the collection" },
    { "type": "range", "id": "products_per_page", "min": 6, "max": 24, "step": 3, "label": "Products per page", "default": 12 }
  ],
  "presets": [{ "name": "Collection page" }]
}
{% endschema %}

{% stylesheet %}
.collection-page {
  background: var(--color-background);
}

.collection-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24px;
}

.collection-sort {
  display: flex;
  gap: 10px;
  align-items: center;
  color: var(--color-muted);
  font-weight: 800;
}

.collection-sort select {
  min-height: 46px;
  border: 1px solid rgba(245, 230, 200, 0.18);
  border-radius: 999px;
  background: var(--color-background);
  color: var(--color-text);
  padding: 0 36px 0 14px;
}

.pagination {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 34px;
}

.pagination a,
.pagination span {
  min-width: 42px;
  height: 42px;
  display: inline-grid;
  place-items: center;
  border-radius: 999px;
  color: var(--color-text);
  text-decoration: none;
  font-weight: 950;
}

.pagination .is-active {
  background: var(--color-accent);
  color: var(--color-accent-text);
}

.empty-state {
  display: grid;
  place-items: center;
  min-height: 360px;
  text-align: center;
  border: 1px solid rgba(245, 230, 200, 0.12);
  border-radius: var(--radius-lg);
  background: rgba(245, 230, 200, 0.04);
}

.empty-state h2 {
  margin: 0 0 12px;
}

.empty-state p {
  color: var(--color-muted);
}

@media (max-width: 760px) {
  .collection-toolbar {
    justify-content: stretch;
  }

  .collection-sort {
    width: 100%;
    justify-content: space-between;
  }

  .collection-sort select {
    flex: 1;
  }
}
{% endstylesheet %}
