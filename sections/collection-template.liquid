<div class="collection-template">
  <div class="collection-header">
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
    <p>{{ collection.description }}</p>
    {% endif %}
  </div>
  
  <div class="collection-filters">
    <button class="filter-btn active">{{ 'sections.collection.all' | t }}</button>
    <button class="filter-btn">S</button>
    <button class="filter-btn">M</button>
    <button class="filter-btn">L</button>
    <button class="filter-btn">XL</button>
  </div>
  
  <div class="product-grid">
    {% for product in collection.products %}
      {% render 'product-card', product: product %}
    {% else %}
      <p class="no-products">{{ 'sections.collection.no_products' | t }}</p>
    {% endfor %}
  </div>
  
  {% if paginate.pages > 1 %}
  <div class="pagination">
    {% if paginate.previous %}
      <a href="{{ paginate.previous.url }}">&laquo;</a>
    {% endif %}
    
    {% for part in paginate.parts %}
      {% if part.is_link %}
        <a href="{{ part.url }}">{{ part.title }}</a>
      {% else %}
        {% if part.title == paginate.current_page %}
          <span class="active">{{ part.title }}</span>
        {% else %}
          <span>{{ part.title }}</span>
        {% endif %}
      {% endif %}
    {% endfor %}
    
    {% if paginate.next %}
      <a href="{{ paginate.next.url }}">&raquo;</a>
    {% endif %}
  </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Collection Template",
  "settings": [],
  "templates": ["collection"]
}
{% endschema %}
