<div class="contact-page">
  <div class="contact-layout">
    <div class="contact-form-wrapper">
      <h2>{{ 'sections.contact.title' | t }}</h2>
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="form-success">{{ 'sections.contact.success' | t }}</p>
        {% endif %}
        
        <div class="form-group">
          <label class="form-label" for="contact-name">{{ 'sections.contact.name' | t }}</label>
          <input type="text" id="contact-name" name="contact[name]" class="form-input" required>
        </div>
        
        <div class="form-group">
          <label class="form-label" for="contact-email">{{ 'sections.contact.email' | t }}</label>
          <input type="email" id="contact-email" name="contact[email]" class="form-input" required>
        </div>
        
        <div class="form-group">
          <label class="form-label" for="contact-message">{{ 'sections.contact.message' | t }}</label>
          <textarea id="contact-message" name="contact[body]" class="form-textarea" required></textarea>
        </div>
        
        <button type="submit" class="btn-gold">{{ 'sections.contact.send' | t }}</button>
      {% endform %}
    </div>
    
    <div class="contact-info">
      <h2>{{ 'sections.contact.info' | t }}</h2>
      <p><strong>{{ 'sections.contact.address' | t }}</strong></p>
      <p>Tashkent, Uzbekistan</p>
      <p><strong>{{ 'sections.contact.email' | t }}:</strong> hello@w8stshop.com</p>
      <p><strong>{{ 'sections.contact.hours' | t }}:</strong> Mon-Sat: 10:00-20:00</p>
      
      <div class="social-links">
        <a href="https://instagram.com/w8stshop" class="social-link">Instagram</a>
        <a href="https://t.me/w8stshop" class="social-link">Telegram</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "settings": [],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
