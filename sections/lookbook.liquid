<section class="section lookbook-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    <div class="lookbook-grid">
      {%- for block in section.blocks -%}
        <a class="lookbook-card" href="{{ block.settings.url | default: '/collections/all' }}">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" width="520" height="640" loading="lazy">
          {% else %}
            <div class="lookbook-placeholder">{{ block.settings.title }}</div>
          {% endif %}
          <span>{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instagram lookbook",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "As worn in Tashkent" },
    { "type": "text", "id": "title", "label": "Title", "default": "Street lookbook" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Real fits, clean details, and urban movement from the W8st community." }
  ],
  "blocks": [
    { "type": "image", "name": "Lookbook image", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Fit check" },
      { "type": "url", "id": "url", "label": "URL", "default": "/collections/all" },
      { "type": "image_picker", "id": "image", "label": "Image" }
    ]}
  ],
  "presets": [
    {
      "name": "Instagram lookbook",
      "blocks": [
        { "type": "image", "settings": { "title": "Look 1" } },
        { "type": "image", "settings": { "title": "Look 2" } },
        { "type": "image", "settings": { "title": "Look 3" } },
        { "type": "image", "settings": { "title": "Look 4" } }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
.lookbook-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
}

.lookbook-card {
  position: relative;
  overflow: hidden;
  min-height: 320px;
  border-radius: var(--radius-md);
  background: rgba(245, 230, 200, 0.06);
  text-decoration: none;
}

.lookbook-card img,
.lookbook-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.lookbook-placeholder {
  display: grid;
  place-items: center;
  color: rgba(232, 184, 75, 0.65);
  font-size: 2rem;
  font-weight: 1000;
  letter-spacing: -0.08em;
  text-transform: uppercase;
}

.lookbook-card span {
  position: absolute;
  left: 14px;
  right: 14px;
  bottom: 14px;
  border-radius: 999px;
  background: rgba(15, 10, 5, 0.78);
  color: var(--color-text);
  padding: 10px 12px;
  font-size: 0.78rem;
  font-weight: 900;
  text-transform: uppercase;
}

@media (max-width: 900px) {
  .lookbook-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 560px) {
  .lookbook-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}
