{% schema %}
{
  "name": "Scrolling Ticker",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Ticker Text",
      "default": "Free Shipping on Orders Over $50 • New Drops Every Week • Wear the Streets. Own the Game."
    }
  ],
  "presets": [
    {
      "name": "Scrolling Ticker"
    }
  ]
}
{% endschema %}
