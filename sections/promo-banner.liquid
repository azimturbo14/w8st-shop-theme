{% stylesheet %}
.promo-banner {
  background-color: #1a1208;
  padding: 60px 20px;
}

.promo-container {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
}

.promo-box {
  border: 3px dashed #e8b84b;
  padding: 60px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.promo-content {
  position: relative;
  z-index: 2;
}

.promo-title {
  font-size: 36px;
  color: #e8b84b;
  margin-bottom: 15px;
  text-transform: uppercase;
}

.promo-text {
  font-size: 20px;
  color: #f5e6c8;
  margin-bottom: 25px;
}

.promo-badge {
  position: absolute;
  top: -20px;
  right: -20px;
  background-color: #e8b84b;
  color: #1a1208;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
  transform: rotate(15deg);
}
{% endstylesheet %}

<div class="promo-banner">
  <div class="promo-container">
    <div class="promo-box">
      <div class="promo-badge">{{ section.settings.badge | default: 'SALE' }}</div>
      <div class="promo-content">
        <h2 class="promo-title">{{ section.settings.heading }}</h2>
        <p class="promo-text">{{ section.settings.text }}</p>
        <a href="{{ section.settings.button_link }}" class="btn-primary">{{ section.settings.button_text }}</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Summer Sale"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Up to 50% off selected items"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Sale"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/sale"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}