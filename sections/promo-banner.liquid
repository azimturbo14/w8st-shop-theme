<section class="promo-banner-section">
  <div class="promo-banner">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    <a href="{{ section.settings.button_link }}" class="btn-gold">{{ section.settings.button_text }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Summer Sale"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Up to 50% off selected items"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Sale"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/sale"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
