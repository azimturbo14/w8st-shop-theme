<section class="section page-section">
  <div class="container page-content empty-state">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>Page not found</h1>
    <p>The page you were looking for does not exist. Continue shopping below.</p>
    <a class="button button--gold" href="/collections/all">Shop products</a>
  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "W8st Shop" }
  ],
  "presets": [{ "name": "404 page" }]
}
{% endschema %}

{% stylesheet %}
.page-section {
  background: var(--color-background);
}

.page-content {
  max-width: 860px;
}

.page-content h1 {
  margin: 0 0 24px;
  font-size: clamp(2.8rem, 8vw, 6rem);
  line-height: 0.95;
  letter-spacing: -0.08em;
  text-transform: uppercase;
}

.rte {
  color: var(--color-muted);
  font-size: 1.05rem;
}

.rte h2,
.rte h3 {
  color: var(--color-text);
  margin-top: 32px;
}

.rte p {
  margin: 0 0 18px;
}

.rte ul,
.rte ol {
  padding-left: 20px;
}

.empty-state {
  display: grid;
  place-items: center;
  min-height: 360px;
  text-align: center;
  border: 1px solid rgba(245, 230, 200, 0.12);
  border-radius: var(--radius-lg);
  background: rgba(245, 230, 200, 0.04);
}
{% endstylesheet %}
