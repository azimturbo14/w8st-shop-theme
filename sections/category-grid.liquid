<section class="section category-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    <div class="category-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign title = block.settings.title
          assign url = block.settings.url
          if title == blank
            assign title = 'Shop now'
          endif
          if url == blank
            assign url = '/collections/all'
          endif
        -%}
        <a class="category-card" href="{{ url }}">
          <div class="category-card__media">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.image.alt | default: title }}" width="520" height="620" loading="lazy">
            {% else %}
              <div class="category-placeholder">{{ title }}</div>
            {% endif %}
          </div>
          <div class="category-card__body">
            <h3>{{ title }}</h3>
            <span>{{ block.settings.button_label | default: 'Shop now' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by vibe" },
    { "type": "text", "id": "title", "label": "Title", "default": "Find your fit" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Streetwear essentials, performance pieces, and accessories for every Tashkent day." }
  ],
  "blocks": [
    { "type": "category", "name": "Category", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Clothing" },
      { "type": "url", "id": "url", "label": "URL", "default": "/collections/clothing" },
      { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop clothing" },
      { "type": "image_picker", "id": "image", "label": "Image" }
    ]}
  ],
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Clothing", "url": "/collections/clothing" } },
        { "type": "category", "settings": { "title": "Sportswear", "url": "/collections/sportswear" } },
        { "type": "category", "settings": { "title": "Accessories", "url": "/collections/accessories" } }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
.category-section {
  background: var(--color-background);
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.category-card {
  position: relative;
  min-height: 460px;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: rgba(245, 230, 200, 0.06);
  color: var(--color-text);
  text-decoration: none;
}

.category-card__media,
.category-card__media img,
.category-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.category-card__media img {
  object-fit: cover;
  transition: transform 0.35s ease;
}

.category-card:hover .category-card__media img {
  transform: scale(1.06);
}

.category-placeholder {
  display: grid;
  place-items: center;
  color: transparent;
  -webkit-text-stroke: 1px rgba(232, 184, 75, 0.7);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 1000;
  letter-spacing: -0.08em;
  text-transform: uppercase;
}

.category-card__body {
  position: absolute;
  inset: auto 0 0;
  padding: 24px;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.78), transparent);
}

.category-card h3 {
  margin: 0 0 8px;
  font-size: clamp(1.6rem, 3vw, 2.5rem);
  letter-spacing: -0.06em;
  text-transform: uppercase;
}

.category-card span {
  display: inline-flex;
  border-radius: 999px;
  background: var(--color-accent);
  color: var(--color-accent-text);
  padding: 10px 14px;
  font-size: 0.78rem;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

@media (max-width: 820px) {
  .category-grid {
    grid-template-columns: 1fr;
  }

  .category-card {
    min-height: 360px;
  }
}
{% endstylesheet %}
