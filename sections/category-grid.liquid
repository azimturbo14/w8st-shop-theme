<section class="category-grid-section">
  <h2 class="section-title">{{ section.settings.title }}</h2>
  <div class="category-grid">
    <a href="/collections/streetwear" class="category-card">
      <h3>Streetwear</h3>
      <p>{{ 'sections.categories.streetwear_desc' | t }}</p>
    </a>
    <a href="/collections/sportswear" class="category-card">
      <h3>Sportswear</h3>
      <p>{{ 'sections.categories.sportswear_desc' | t }}</p>
    </a>
    <a href="/collections/accessories" class="category-card">
      <h3>Accessories</h3>
      <p>{{ 'sections.categories.accessories_desc' | t }}</p>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop by Category"
    }
  ],
  "presets": [
    {
      "name": "Category Grid"
    }
  ]
}
{% endschema %}
