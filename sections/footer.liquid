<footer class="footer">
  <div class="footer-content">
    <div class="footer-top">
      <h3>W8st Shop</h3>
      <p>{{ 'sections.footer.tagline' | t }}</p>
    </div>
    <div class="footer-grid">
      <div class="footer-column">
        <h4>{{ 'sections.footer.shop' | t }}</h4>
        <ul>
          <li><a href="/collections/new-arrivals">{{ 'sections.header.new' | t }}</a></li>
          <li><a href="/collections/clothing">{{ 'sections.header.clothes' | t }}</a></li>
          <li><a href="/collections/sportswear">{{ 'sections.header.sport' | t }}</a></li>
          <li><a href="/collections/sale">{{ 'sections.header.sale' | t }}</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>{{ 'sections.footer.help' | t }}</h4>
        <ul>
          <li><a href="/pages/shipping">{{ 'sections.footer.shipping' | t }}</a></li>
          <li><a href="/pages/returns">{{ 'sections.footer.returns' | t }}</a></li>
          <li><a href="/pages/contact">{{ 'sections.header.contact' | t }}</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>{{ 'sections.footer.about' | t }}</h4>
        <ul>
          <li><a href="/pages/about">{{ 'sections.footer.our_story' | t }}</a></li>
          <li><a href="/pages/careers">{{ 'sections.footer.careers' | t }}</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>{{ 'sections.footer.social' | t }}</h4>
        <ul>
          <li><a href="https://instagram.com/w8stshop" class="social-link">Instagram</a></li>
          <li><a href="https://t.me/w8stshop" class="social-link">Telegram</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} W8st Shop Tashkent. {{ 'sections.footer.all_rights' | t }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
