<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="logo-text">{{ shop.name }}</a>
      <p>{{ settings.tagline }}</p>
      <p>{{ settings.location }}</p>
      <div class="social-links">
        <a href="{{ settings.instagram_url }}" target="_blank" rel="noreferrer">Instagram</a>
        <a href="{{ settings.telegram_url }}" target="_blank" rel="noreferrer">Telegram</a>
      </div>
    </div>

    <div>
      <h3>{{ settings.footer_column_1_title }}</h3>
      <ul>
        {%- assign links = settings.footer_column_1_links | split: "\n" -%}
        {%- for link in links -%}
          {%- if link != blank -%}
            <li><a href="/collections/{{ link | handle }}">{{ link }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <div>
      <h3>{{ settings.footer_column_2_title }}</h3>
      <ul>
        <li><a href="/pages/about">{{ 'sections.footer.about' | t }}</a></li>
        <li><a href="/pages/contact">{{ 'sections.footer.contact' | t }}</a></li>
        <li><a href="/pages/shipping-returns">{{ 'sections.footer.shipping_returns' | t }}</a></li>
      </ul>
    </div>

    <div class="footer-newsletter">
      <h3>{{ 'sections.footer.newsletter' | t }}</h3>
      <p>{{ 'sections.footer.newsletter_text' | t }}</p>
      <form class="newsletter-form" action="/contact#newsletter" method="post">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="sr-only" for="NewsletterEmail">{{ 'sections.footer.email' | t }}</label>
        <input id="NewsletterEmail" name="contact[email]" type="email" placeholder="{{ 'sections.footer.email_placeholder' | t }}" required>
        <button class="button button--gold" type="submit">{{ 'sections.footer.subscribe' | t }}</button>
      </form>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.copyright' | t }}</p>
    <p>{{ 'sections.footer.secure_checkout' | t }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Wear the streets. Own the game." },
    { "type": "text", "id": "location", "label": "Location", "default": "Tashkent, Uzbekistan" },
    { "type": "text", "id": "footer_column_1_title", "label": "Footer column 1 title", "default": "Shop" },
    { "type": "textarea", "id": "footer_column_1_links", "label": "Footer column 1 links", "default": "New Arrivals\nClothing\nSportswear\nAccessories" },
    { "type": "text", "id": "footer_column_2_title", "label": "Footer column 2 title", "default": "Help" },
    { "type": "textarea", "id": "footer_column_2_links", "label": "Footer column 2 links", "default": "About\nContact\nShipping & Returns" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL", "default": "https://instagram.com/w8stshop" },
    { "type": "url", "id": "telegram_url", "label": "Telegram URL", "default": "https://t.me/w8stshop" }
  ]
}
{% endschema %}

{% stylesheet %}
.site-footer {
  margin-top: 80px;
  padding: 56px 0 24px;
  background: #0f0a05;
  color: var(--color-text);
  border-top: 1px solid rgba(245, 230, 200, 0.12);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.3fr repeat(2, minmax(130px, 1fr)) 1.4fr;
  gap: 32px;
}

.footer-brand p,
.footer-newsletter p {
  color: var(--color-muted);
  margin: 12px 0 0;
}

.footer-grid h3 {
  margin: 0 0 16px;
  font-size: 0.86rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.footer-grid ul {
  display: grid;
  gap: 10px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.footer-grid a {
  color: var(--color-muted);
  text-decoration: none;
}

.footer-grid a:hover,
.footer-grid a:focus-visible {
  color: var(--color-accent);
}

.social-links {
  display: flex;
  gap: 14px;
  margin-top: 18px;
}

.newsletter-form {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  margin-top: 16px;
}

.newsletter-form input {
  min-width: 0;
  border: 1px solid rgba(245, 230, 200, 0.18);
  border-radius: 999px;
  background: rgba(245, 230, 200, 0.06);
  color: var(--color-text);
  padding: 12px 14px;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  margin-top: 40px;
  padding-top: 22px;
  border-top: 1px solid rgba(245, 230, 200, 0.12);
  color: var(--color-muted);
  font-size: 0.82rem;
}

@media (max-width: 820px) {
  .footer-grid {
    grid-template-columns: 1fr;
  }

  .footer-bottom {
    flex-direction: column;
  }
}
{% endstylesheet %}
