<section class="hero-section section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="hero-actions">
        <a class="button button--gold" href="{{ section.settings.primary_button_url }}">{{ section.settings.primary_button_label }}</a>
        <a class="button button--outline" href="{{ section.settings.secondary_button_url }}">{{ section.settings.secondary_button_label }}</a>
      </div>
    </div>
    <div class="hero-card" aria-label="{{ section.settings.heading }}">
      <div class="hero-card__image">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image.alt | default: section.settings.heading }}" width="620" height="720" loading="eager">
        {% else %}
          <div class="hero-placeholder">
            <span>W8ST</span>
            <strong>{{ settings.tagline }}</strong>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tashkent streetwear" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wear the streets. Own the game." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Clean urban fits, performance sportswear, and everyday essentials built for Tashkent." },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "primary_button_label", "label": "Primary button", "default": "Shop new drops" },
    { "type": "url", "id": "primary_button_url", "label": "Primary URL", "default": "/collections/new-arrivals" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button", "default": "Explore sportswear" },
    { "type": "url", "id": "secondary_button_url", "label": "Secondary URL", "default": "/collections/sportswear" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}

{% stylesheet %}
.hero-section {
  padding: clamp(48px, 7vw, 96px) 0;
  background:
    radial-gradient(circle at 80% 10%, rgba(232, 184, 75, 0.22), transparent 32%),
    linear-gradient(135deg, var(--color-background), #2a1a0b);
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.85fr);
  gap: clamp(28px, 5vw, 72px);
  align-items: center;
}

.hero-copy h1 {
  max-width: 760px;
  margin: 0;
  font-size: clamp(3rem, 10vw, 7.8rem);
  line-height: 0.88;
  letter-spacing: -0.09em;
  text-transform: uppercase;
}

.hero-copy > p:not(.eyebrow) {
  max-width: 560px;
  color: var(--color-muted);
  font-size: clamp(1rem, 2vw, 1.2rem);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}

.hero-card {
  position: relative;
}

.hero-card__image {
  position: relative;
  min-height: 520px;
  overflow: hidden;
  border: 1px solid rgba(245, 230, 200, 0.14);
  border-radius: var(--radius-lg);
  background: rgba(245, 230, 200, 0.06);
  box-shadow: 0 28px 80px rgba(0, 0, 0, 0.35);
}

.hero-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-placeholder {
  min-height: 520px;
  display: grid;
  place-items: center;
  text-align: center;
  padding: 32px;
}

.hero-placeholder span {
  color: transparent;
  -webkit-text-stroke: 2px rgba(232, 184, 75, 0.8);
  font-size: clamp(4rem, 13vw, 10rem);
  font-weight: 1000;
  letter-spacing: -0.12em;
}

.hero-placeholder strong {
  display: block;
  max-width: 320px;
  margin-top: 18px;
  color: var(--color-accent);
  text-transform: uppercase;
}

@media (max-width: 820px) {
  .hero-grid {
    grid-template-columns: 1fr;
  }

  .hero-card__image,
  .hero-placeholder {
    min-height: 420px;
  }

  .hero-actions .button {
    width: 100%;
    text-align: center;
  }
}
{% endstylesheet %}
