{% stylesheet %}
.hero-banner {
  background-color: #1a1208;
  color: #f5e6c8;
  padding: 120px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-content {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}

.hero-title {
  font-size: 48px;
  font-weight: 700;
  margin-bottom: 20px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.hero-subtitle {
  font-size: 24px;
  color: #b8a882;
  margin-bottom: 40px;
  font-style: italic;
}

.hero-buttons {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-primary {
  background-color: #e8b84b;
  color: #1a1208;
  border: none;
  padding: 15px 40px;
  font-size: 16px;
  font-weight: 600;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  display: inline-block;
}

.btn-primary:hover {
  background-color: #f5e6c8;
  transform: translateY(-2px);
}

.btn-secondary {
  background-color: transparent;
  color: #f5e6c8;
  border: 2px solid #e8b84b;
  padding: 15px 40px;
  font-size: 16px;
  font-weight: 600;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  display: inline-block;
}

.btn-secondary:hover {
  background-color: #e8b84b;
  color: #1a1208;
}

@media (max-width: 768px) {
  .hero-title {
    font-size: 32px;
  }

  .hero-subtitle {
    font-size: 18px;
  }

  .hero-buttons {
    flex-direction: column;
  }
}
{% endstylesheet %}

<div class="hero-banner">
  <div class="hero-content">
    <h1 class="hero-title">{{ section.settings.heading }}</h1>
    <p class="hero-subtitle">{{ section.settings.subheading }}</p>
    <div class="hero-buttons">
      <a href="{{ section.settings.button_link }}" class="btn-primary">{{ section.settings.button_text }}</a>
      <a href="/collections/all" class="btn-secondary">{{ section.settings.button2_text | default: 'View Lookbook' }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear the streets. Own the game."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium streetwear from Tashkent"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button2_text",
      "label": "Second Button Text",
      "default": "View Lookbook"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}