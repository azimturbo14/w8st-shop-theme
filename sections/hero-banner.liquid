<section class="hero-banner">
  <div class="hero-content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <div class="hero-buttons">
      <a href="{{ section.settings.button_link }}" class="btn-gold">{{ section.settings.button_text }}</a>
      <a href="/collections/all" class="btn-outline">{{ section.settings.button2_text | default: 'View Lookbook' }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear the streets. Own the game."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium streetwear from Tashkent"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button2_text",
      "label": "Second Button Text",
      "default": "View Lookbook"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
