<div class="product-template">
  <div class="product-main">
    <div class="product-gallery">
      <div class="product-main-image">
        <img src="{{ product.featured_image | img_url: '1000x' }}" alt="{{ product.title }}" id="main-product-image">
      </div>
      {% if product.images.size > 1 %}
      <div class="product-thumbnails">
        {% for image in product.images %}
        <div class="thumbnail {% if forloop.first %}active{% endif %}">
          <img src="{{ image | img_url: '200x' }}" alt="{{ product.title }}">
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    
    <div class="product-info">
      <h1 class="product-title">{{ product.title }}</h1>
      <div class="product-price">
        {% if product.compare_at_price > product.price %}
          <span class="price-sale">{{ product.price | money }}</span>
          <span class="price-original">{{ product.compare_at_price | money }}</span>
        {% else %}
          <span>{{ product.price | money }}</span>
        {% endif %}
      </div>
      
      <form data-add-to-cart class="product-form">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <div class="product-options">
          {% if product.has_only_default_variant == false %}
            {% for option in product.options_with_values %}
            <div class="option-group">
              <label class="option-label">{{ option.name }}</label>
              {% if option.name == 'Size' %}
              <div class="size-selector">
                {% for value in option.values %}
                <button type="button" class="size-btn {% if option.selected_value == value %}selected{% endif %}" 
                        data-value="{{ value }}">{{ value }}</button>
                {% endfor %}
                <button type="button" data-open-size-guide style="margin-left: 0.5rem; font-size: 0.75rem; color: #b8a882;">{{ 'products.product.size_guide' | t }}</button>
              </div>
              {% elsif option.name == 'Color' %}
              <div class="color-selector">
                {% for value in option.values %}
                <button type="button" class="color-btn {% if option.selected_value == value %}selected{% endif %}" 
                        style="background: {{ value | handleize }};" data-value="{{ value }}"></button>
                {% endfor %}
              </div>
              {% else %}
              <select name="options[{{ option.name }}]" class="form-input">
                {% for value in option.values %}
                <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {% endfor %}
              </select>
              {% endif %}
            </div>
            {% endfor %}
          {% endif %}
        </div>
        
        <div class="quantity-selector">
          <label class="option-label">{{ 'products.product.quantity' | t }}</label>
          <input type="number" name="quantity" value="1" min="1" class="qty-input">
        </div>
        
        <button type="submit" class="add-to-cart-btn">{{ 'products.product.add_to_cart' | t }}</button>
      </form>
      
      <div class="accordion">
        <div class="accordion-item">
          <button class="accordion-header">
            {{ 'products.product.description' | t }}
            <span>+</span>
          </button>
          <div class="accordion-content">
            {{ product.description }}
          </div>
        </div>
        <div class="accordion-item">
          <button class="accordion-header">
            {{ 'products.product.shipping' | t }}
            <span>+</span>
          </button>
          <div class="accordion-content">
            <p>{{ 'products.product.shipping_info' | t }}</p>
          </div>
        </div>
        <div class="accordion-item">
          <button class="accordion-header">
            {{ 'products.product.returns' | t }}
            <span>+</span>
          </button>
          <div class="accordion-content">
            <p>{{ 'products.product.returns_info' | t }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  {% if recommendations.products_count > 0 %}
  <div class="related-products">
    <h2>{{ 'products.product.related' | t }}</h2>
    <div class="product-grid">
      {% for product in recommendations.products limit: 4 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

{% render 'size-guide-modal' %}

{% schema %}
{
  "name": "Product Template",
  "settings": [],
  "templates": ["product"]
}
{% endschema %}
