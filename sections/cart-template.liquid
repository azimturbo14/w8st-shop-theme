<div class="cart-template">
  <div class="cart-page">
    <h1 class="cart-page-title">{{ 'sections.cart.title' | t }}</h1>
    
    {% if cart.item_count > 0 %}
    <div class="cart-layout">
      <div class="cart-items-list">
        {% for item in cart.items %}
        <div class="cart-item">
          <div class="cart-item-image">
            <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title }}">
          </div>
          <div class="cart-item-details">
            <h3 class="cart-item-name">{{ item.product.title }}</h3>
            <p class="cart-item-variant">{{ item.variant.title }}</p>
            <p class="cart-item-price">{{ item.final_line_price | money }}</p>
            <div class="cart-item-quantity">
              <button class="qty-btn" onclick="updateCartItem({{ item.key }}, {{ item.quantity | minus: 1 }})">-</button>
              <span>{{ item.quantity }}</span>
              <button class="qty-btn" onclick="updateCartItem({{ item.key }}, {{ item.quantity | plus: 1 }})">+</button>
              <button class="cart-item-remove" onclick="removeCartItem({{ item.key }})">{{ 'sections.cart.remove' | t }}</button>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      
      <div class="cart-summary">
        <div class="summary-row">
          <span>{{ 'sections.cart.subtotal' | t }}</span>
          <span class="summary-total">{{ cart.total_price | money }}</span>
        </div>
        <p class="shipping-note">{{ 'sections.cart.shipping_note' | t }}</p>
        <a href="/checkout" class="cart-checkout-btn">{{ 'sections.cart.checkout' | t }}</a>
        <a href="/collections/all" class="cart-continue">{{ 'sections.cart.continue_shopping' | t }}</a>
      </div>
    </div>
    {% else %}
    <div class="no-results">
      <p>{{ 'sections.cart.empty' | t }}</p>
      <a href="/collections/all" class="btn-gold" style="display: inline-block; margin-top: 1rem;">{{ 'sections.cart.continue_shopping' | t }}</a>
    </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cart Template",
  "settings": [],
  "templates": ["cart"]
}
{% endschema %}
